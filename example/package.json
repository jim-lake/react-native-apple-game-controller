{
  "name": "GameControllerExample",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint . --fix",
    "ts:check": "tsc --noEmit",
    "pretty": "prettier --write *.js *.json src",
    "start": "react-native start",
    "test": "jest",
    "build:macos": "LOGFILE=/tmp/rngc-example-build-$(date +%s).log; react-native build-macos --mode Debug > $LOGFILE 2>&1 && echo \"BUILD SUCCEEDED — $LOGFILE\" || (echo \"BUILD FAILED — $LOGFILE\"; exit 1)",
    "run:macos": "react-native run-macos --mode Debug"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.81.2",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-apple-game-controller": "file:..",
    "react-native-macos": "^0.81.7",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^9.39.4",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.2",
    "@react-native/metro-config": "0.81.2",
    "@react-native/typescript-config": "0.81.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.6.3",
    "prettier": "3.x",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0"
  },
  "engines": {
    "node": ">=20"
  }
}
