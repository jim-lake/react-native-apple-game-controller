{
  "name": "react-native-apple-game-controller",
  "version": "0.0.1",
  "description": "Apple Game Controller support for React Native macOS",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "spec",
    "src",
    "macos",
    "react-native-apple-game-controller.podspec",
    "!**/__tests__"
  ],
  "scripts": {
    "pretty": "prettier --write src spec && clang-format -i macos/*",
    "ts:check": "tsc --noEmit",
    "test": "node --experimental-test-module-mocks --import tsx --test tests/**/*.test.ts",
    "lint": "eslint . --fix"
  },
  "keywords": [
    "react-native",
    "macos",
    "game-controller",
    "gamepad"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.1.4",
    "react-native": "^0.81.6",
    "react-native-macos": ">=0.81.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.1"
  },
  "codegenConfig": {
    "name": "RNGameControllerSpec",
    "type": "modules",
    "jsSrcsDir": "spec"
  }
}
