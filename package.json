{
  "name": "react-native-apple-game-controller",
  "version": "0.0.1",
  "description": "Apple Game Controller support for React Native macOS",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "spec",
    "src",
    "macos",
    "react-native-apple-game-controller.podspec",
    "!**/__tests__"
  ],
  "scripts": {
    "pretty": "prettier --write src spec && clang-format -i macos/*",
    "ts:check": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "macos",
    "game-controller",
    "gamepad"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.1.4",
    "react-native": "^0.81.6",
    "react-native-macos": ">=0.81.0"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^5.4.0"
  },
  "codegenConfig": {
    "name": "RNGameControllerSpec",
    "type": "modules",
    "jsSrcsDir": "spec"
  }
}
